# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                 # development | staging | production
CORS_ORIGINS=http://localhost:3000
DEV_BYPASS_AUTH=false                   # never true in staging/production
REQUIRE_HUMAN_ON_ALL=false              # four-eyes master switch (forces human sign-off)

# ── Service-to-service auth ───────────────────────────────────────────────────
# Shared secret presented as X-Service-Key by n8n (→ this shim) and by this shim
# (→ P3/P2). Generate a long random value; store only in Railway/n8n secrets.
AGENT_FLOW_SERVICE_KEY=

# ── Upstream tools (the shim proxies these) ───────────────────────────────────
DOCI_BASE_URL=https://document-intelligence-backend.up.railway.app
LLC_BASE_URL=https://llm-council-backend.up.railway.app

# ── n8n resume (human gate) ───────────────────────────────────────────────────
# Base URL the shim calls to resume a paused n8n Wait node after an approval.
N8N_RESUME_BASE_URL=

# ── Supabase (run state + governance events) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
